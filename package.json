{
  "name": "hodoku-ts",
  "version": "0.0.0",
  "description": "TypeScript port of the HoDoKu Sudoku generator and human-style solver/hint engine",
  "license": "GPL-3.0-or-later",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "rolldown"]
  },
  "keywords": [
    "sudoku",
    "solver",
    "generator",
    "hint",
    "puzzle",
    "hodoku"
  ],
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsdown": "^0.9.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.8"
  }
}
